{
  "name": "midefensaperu-backend",
  "version": "1.0.0",
  "description": "Marketplace de abogados en Perú - Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:debug": "ts-node-dev --inspect --respawn --transpile-only src/main.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "ts-node scripts/seed.ts",
    "test": "echo \"Tests pending\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erickManVar/midefensaperu-backend.git"
  },
  "keywords": ["nestjs", "fastify", "drizzle", "postgresql", "marketplace", "lawyers", "peru"],
  "author": "MiDefensaPeru Team",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@neondatabase/serverless": "^0.10.4",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/throttler": "^6.4.0",
    "better-auth": "^1.2.7",
    "bullmq": "^5.47.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "drizzle-orm": "^0.40.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "node-cache": "^5.1.2",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.1.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/node": "^22.13.14",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
