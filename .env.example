# ============================================================
# MIDEFENSAPERU BACKEND - Variables de Entorno
# Copia este archivo a .env y completa los valores
# ============================================================

# --- BASE DE DATOS (Neon PostgreSQL) ---
# Obtener desde: https://neon.tech/dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/midefensaperu?sslmode=require

# --- REDIS (para BullMQ) ---
# Local: redis://localhost:6379
# Producción: URL de Redis Cloud / Upstash
REDIS_URL=redis://localhost:6379

# --- JWT SECRET ---
# Generar con: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# --- CULQI (Pagos) ---
# Obtener desde: https://culqi.com/dashboard
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxx
CULQI_URL=https://api.culqi.com/v2

# --- RESEND (Emails) ---
# Obtener desde: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@midefensaperu.com

# --- FRONTEND URLs (CORS) ---
FRONTEND_URL=http://localhost:3000
BACKOFFICE_URL=http://localhost:3001

# --- SERVIDOR ---
PORT=4000
NODE_ENV=development

# --- BETTER-AUTH ---
BETTER_AUTH_SECRET=your-better-auth-secret-change-in-production
BETTER_AUTH_URL=http://localhost:4000

# --- ESCROW CONFIG ---
# Porcentaje de comision de la plataforma (default 20%)
PLATFORM_COMMISSION_PERCENT=20
# Dias para auto-release del escrow si no hay confirmacion
ESCROW_AUTO_RELEASE_DAYS=7
